{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_ff <= 147",
    "not chrome <= 112",
    "not firefox <= 147",
    "not samsung <= 29"
  ],
  "hints": {
    "axe/aria": "off",
    "no-inline-styles": "off",
    "meta-viewport": "off",
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ]
  }
}