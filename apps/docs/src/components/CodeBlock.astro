---
import { codeToHtml } from "shiki";

interface Props {
  code: string;
  language?: string;
  title?: string;
}

const { code, language = "html", title } = Astro.props;

function trimSurroundingBlankLines(value: string): string {
  const lines = value.split("\n");

  while (lines.length > 0 && lines[0].trim() === "") {
    lines.shift();
  }

  while (lines.length > 0 && lines[lines.length - 1].trim() === "") {
    lines.pop();
  }

  return lines.join("\n");
}

const normalizedCode = trimSurroundingBlankLines(code);

const html = await codeToHtml(normalizedCode, {
  lang: language,
  theme: "plastic",
});
---

<div class="code-block">
  {title && <div class="code-block__title">{title}</div>}
  <div set:html={html} />
</div>

