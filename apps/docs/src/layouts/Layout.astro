---
import 'le-kit/dist/themes/index.css';
import '../styles/global.css';
import { mainNavigationItems } from '../data/navigation';
import { readFile } from 'node:fs/promises';

import '@fontsource-variable/sour-gummy/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '@fontsource-variable/sofia-sans-semi-condensed/wght.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

let coreVersion = 'dev';
try {
  const packageJsonRaw = await readFile(new URL('../../../../packages/core/package.json', import.meta.url), 'utf8');
  const packageJson = JSON.parse(packageJsonRaw) as { version?: string };
  if (packageJson.version) {
    coreVersion = packageJson.version;
  }
} catch {
  // Keep fallback for environments where the workspace file is unavailable.
}
---

<!doctype html>
<html lang="en" class="le-theme-light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Le-Kit Documentation" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      html:not(.le-ready) body {
        visibility: hidden;
      }
    </style>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const show = () => root.classList.add('le-ready');

        if (!('customElements' in window)) {
          show();
          return;
        }

        const run = async () => {
          const tags = [...document.querySelectorAll('*')]
            .map((el) => el.localName)
            .filter((name) => name.startsWith('le-'));

          const uniqueTags = [...new Set(tags)];
          await Promise.all(uniqueTags.map((tag) => customElements.whenDefined(tag)));
          show();
        };

        if (document.readyState === 'loading') {
          document.addEventListener(
            'DOMContentLoaded',
            () => {
              void run();
            },
            { once: true },
          );
        } else {
          void run();
        }

        setTimeout(show, 3000);
      })();
    </script>
    <script type="module" src="/le-kit/le-kit/le-kit.esm.js" is:inline></script>
    <script nomodule src="/le-kit/le-kit/le-kit.js" is:inline></script>
  </head>
  <body>
    <le-header layout="space-between" class="header" fixed>
      <div slot="start" class="header--start">
        <a href="/">
          <img src="/le-kit.svg" alt="le-kit logo" class="header--logo" />
        </a>
        <span class="header--version">v{coreVersion}</span>
      </div>
      <le-navigation slot="end" overflow-mode="hamburger" hamburger-align="end">
        {
          mainNavigationItems.map((item) => (
            <le-item
              label={item.label}
              href={item.href}
              icon-end={item.iconEnd}
              part={item.part}
              selected={item.href && Astro.url.pathname.startsWith(item.href) ? true : undefined}
            />
          ))
        }
      </le-navigation>
      <le-button href="https://github.com/leechy/le-kit" target="_blank" icon-only variant="clear" slot="end"
        ><img
          slot="icon-only"
          src="/icons/github.svg"
          alt="Go to GitHub repository"
          width="22"
          height="22"
        /></le-button
      >
    </le-header>
    <le-header-placeholder></le-header-placeholder>

    <slot />
  </body>
</html>
