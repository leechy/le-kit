---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  const posts = await getCollection(
    "blog",
    ({ data }) => data.published && !data.draft,
  );

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
const dateFormatter = new Intl.DateTimeFormat("en-US", { dateStyle: "long" });
---

<Layout title={`${post.data.title} - Blog - Le-Kit`}>
  <article class="post-page">
    <a class="back-link" href="/blog">← Back to all posts</a>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      <p class="post-meta">{dateFormatter.format(post.data.publishDate)}</p>
      <div class="post-tags">
        {
          post.data.tags.map((tag) => (
            <a href={`/blog?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
          ))
        }
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>

  <style>
    .post-page {
      max-width: 900px;
      margin: 0 auto;
      padding: var(--le-spacing-6) var(--le-spacing-4) var(--le-spacing-8);
      display: grid;
      gap: var(--le-spacing-4);
    }

    .back-link {
      color: var(--le-color-primary);
      text-decoration: none;
      width: fit-content;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .post-header {
      display: grid;
      gap: var(--le-spacing-2);
    }

    .post-header h1,
    .post-description,
    .post-meta {
      margin: 0;
    }

    .post-description {
      font-size: var(--le-font-size-lg);
      color: var(--le-color-text-muted);
    }

    .post-meta {
      font-size: var(--le-font-size-sm);
      color: var(--le-color-text-muted);
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--le-spacing-2);
    }

    .post-tags a {
      color: var(--le-color-primary);
      text-decoration: none;
    }

    .post-tags a:hover {
      text-decoration: underline;
    }

    .post-content {
      border: 1px solid var(--le-color-border);
      border-radius: var(--le-radius-lg);
      padding: var(--le-spacing-4);
      background: color-mix(in srgb, var(--le-color-surface), white 24%);
    }

    .post-content :global(p) {
      line-height: 1.7;
    }

    .post-content :global(h2) {
      margin-top: var(--le-spacing-5);
    }

    .post-content :global(le-card) {
      margin: var(--le-spacing-4) 0;
      display: block;
    }
  </style>
</Layout>
