---
import ComponentsPage from "../../layouts/ComponentsPage.astro";
---

<ComponentsPage title="Components">
  <le-stack gap="var(--le-spacing-xl)">
    <div>
      <le-text typography="h1">Components</le-text>
      <le-text typography="body-large"
        >Browse the le-kit component library.</le-text
      >
    </div>

    <le-card>
      <div slot="header">
        <le-text typography="h3">Explore by Category</le-text>
      </div>
      <le-stack gap="var(--le-spacing-md)">
        <le-text typography="body"
          >Use the side navigation to browse layout, form, overlay, admin, and
          legacy components.</le-text
        >
        <le-text typography="body"
          >Each component page can now share the same layout, breadcrumbs, and
          navigation structure.</le-text
        >
      </le-stack>
    </le-card>
  </le-stack>
</ComponentsPage>
