---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Components - le-kit">
  <le-side-panel
    panel-id="side-navigation"
    resizable
    persist-key="components-panel"
    collapse-at="900"
    narrow-behavior="overlay"
    class="side-panel"
    sticky
    top="under-header"
    full-height
  >
    <le-navigation
      class="side-panel-navigation"
      slot="panel"
      orientation="vertical"
      activeUrl={Astro.url.pathname}
    >
      <le-item label="Layout & Navigation" open id="layout-navigation">
        <le-item
          label="Header"
          href="/components/le-header"
          selected={Astro.url.pathname.startsWith("/components/le-header") ||
            undefined}></le-item>
        <le-item
          label="Scroll Progress"
          href="/components/le-scroll-progress"
          selected={Astro.url.pathname.startsWith(
            "/components/le-scroll-progress",
          ) || undefined}></le-item>
        <le-item
          label="Side Panel"
          href="/components/le-side-panel"
          selected={Astro.url.pathname.startsWith(
            "/components/le-side-panel",
          ) || undefined}></le-item>
        <le-item
          label="Bar"
          href="/components/le-bar"
          selected={Astro.url.pathname.startsWith("/components/le-bar") ||
            undefined}></le-item>
        <le-item
          label="Navigation"
          href="/components/le-navigation"
          selected={Astro.url.pathname.startsWith(
            "/components/le-navigation",
          ) || undefined}></le-item>
        <le-item label="Tabs" open id="tabs">
          <le-item
            label="Tabs"
            href="/components/le-tabs"
            selected={Astro.url.pathname.startsWith("/components/le-tabs") ||
              undefined}
            open
            id="tabs"></le-item>
          <le-item
            label="Tab"
            href="/components/le-tab"
            selected={Astro.url.pathname.startsWith("/components/le-tab") ||
              undefined}></le-item>
          <le-item
            label="Tab Bar"
            href="/components/le-tab-bar"
            selected={Astro.url.pathname.startsWith("/components/le-tab-bar") ||
              undefined}></le-item>
          <le-item
            label="Tab Panel"
            href="/components/le-tab-panel"
            selected={Astro.url.pathname.startsWith(
              "/components/le-tab-panel",
            ) || undefined}></le-item>
        </le-item>
        <le-item
          label="Breadcrumbs"
          href="/components/le-breadcrumbs"
          selected={Astro.url.pathname.startsWith(
            "/components/le-breadcrumbs",
          ) || undefined}></le-item>
      </le-item>
      <le-item label="Form Controls" open id="form-controls">
        <le-item
          label="Button"
          href="/components/le-button"
          selected={Astro.url.pathname.startsWith("/components/le-button") ||
            undefined}></le-item>
        <le-item
          label="Checkbox"
          href="/components/le-checkbox"
          selected={Astro.url.pathname.startsWith("/components/le-checkbox") ||
            undefined}></le-item>
        <le-item label="Inputs" open id="form-inputs">
          <le-item
            label="Text Input"
            href="/components/le-text-input"
            selected={Astro.url.pathname.startsWith(
              "/components/le-text-input",
            ) || undefined}></le-item>
          <le-item
            label="Number Input"
            href="/components/le-number-input"
            selected={Astro.url.pathname.startsWith(
              "/components/le-number-input",
            ) || undefined}></le-item>
          <le-item
            label="Code Input"
            href="/components/le-code-input"
            selected={Astro.url.pathname.startsWith(
              "/components/le-code-input",
            ) || undefined}></le-item>
        </le-item>
        <le-item label="Dropdowns" open id="form-dropdowns">
          <le-item
            label="Select"
            href="/components/le-select"
            selected={Astro.url.pathname.startsWith("/components/le-select") ||
              undefined}></le-item>
          <le-item
            label="Combo Box"
            href="/components/le-combobox"
            selected={Astro.url.pathname.startsWith(
              "/components/le-combobox",
            ) || undefined}></le-item>
          <le-item
            label="Multi Select"
            href="/components/le-multiselect"
            selected={Astro.url.pathname.startsWith(
              "/components/le-multiselect",
            ) || undefined}></le-item>
        </le-item>
      </le-item>
      <le-item label="Overlays" open id="overlays">
        <le-item
          label="Popover"
          href="/components/le-popover"
          selected={Astro.url.pathname.startsWith("/components/le-popover") ||
            undefined}></le-item>
        <le-item
          label="Popup"
          href="/components/le-popup"
          selected={Astro.url.pathname.startsWith("/components/le-popup") ||
            undefined}></le-item>
      </le-item>
      <le-item label="Admin" open id="admin-components">
        <le-item
          label="Component"
          href="/components/le-component"
          selected={Astro.url.pathname.startsWith("/components/le-component") ||
            undefined}></le-item>
        <le-item
          label="Slot"
          href="/components/le-slot"
          selected={Astro.url.pathname.startsWith("/components/le-slot") ||
            undefined}></le-item>
      </le-item>
      <le-item label="Legacy" open id="legacy-components">
        <le-item
          label="Round Progress"
          href="/components/le-round-progress"
          selected={Astro.url.pathname.startsWith(
            "/components/le-round-progress",
          ) || undefined}></le-item>
        <le-item
          label="Turntable"
          href="/components/le-turntable"
          selected={Astro.url.pathname.startsWith("/components/le-turntable") ||
            undefined}></le-item>
      </le-item>
    </le-navigation>

    <div>
      <le-breadcrumbs
        items='[
          { "label": "Le-Kit", "href": "/" },
          { "label": "Components" }
        ]'
      >
        <le-side-panel-toggle
          slot="start"
          panel-id="side-navigation"
          action="toggle"
          shortcut="Mod+B"
          variant="clear"
          icon-only="true"
          style={{
            "--le-button-icon-only-padding": "var(--le-space-xs)",
          }}
        >
          <le-icon slot="icon-only" name="side-panel"></le-icon>
        </le-side-panel-toggle>
      </le-breadcrumbs>
      <main style="max-width: 1200px; margin: 2rem auto; padding: 0 1rem;">
        <h1>
