---
import ComponentsPage from "../../layouts/ComponentsPage.astro";
---

<ComponentsPage title="le-button">
  <le-stack gap="var(--le-spacing-xl)">
    <div>
      <le-text typography="h1">le-button</le-text>
      <le-text typography="body-large"
        >A flexible button component with multiple variants and states.</le-text
      >
    </div>

    <le-card>
      <div slot="header">
        <le-text typography="h3">Examples</le-text>
      </div>
      <le-stack gap="var(--le-spacing-md)">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <le-button variant="solid" color="primary">Solid</le-button>
          <le-button variant="outlined" color="primary">Outlined</le-button>
          <le-button variant="clear" color="primary">Clear</le-button>
        </div>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <le-button variant="solid" color="secondary">Secondary</le-button>
          <le-button variant="solid" color="success">Success</le-button>
          <le-button variant="solid" color="danger">Danger</le-button>
        </div>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <le-button size="small">Small</le-button>
          <le-button size="medium">Medium</le-button>
          <le-button size="large">Large</le-button>
        </div>
      </le-stack>
    </le-card>

    <div>
      <le-text typography="h2">API Reference</le-text>
    </div>
  </le-stack>
</ComponentsPage>
