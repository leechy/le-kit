---
import ComponentsPage from "../../layouts/ComponentsPage.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<ComponentsPage title="le-code-input">
  <h1>&lt;le-code-input&gt;</h1>
  <p>One-time code input with individual character frames and paste-friendly behavior.</p>

  <h2><a href="#examples" id="examples">Examples</a></h2>
  <div class="component-example">
    <le-code-input label="Verification code" length="6" placeholder="000000"></le-code-input>
  </div>

  <CodeBlock language="html" code={`
<le-code-input
  name="otp"
  label="Enter 6-digit code"
  length="6"
></le-code-input>`}
  />

  <h2><a href="#properties" id="properties">Common Properties / Attributes</a></h2>
  <ul>
    <li><code>value</code>, <code>name</code>, <code>label</code>, <code>length</code></li>
    <li><code>description</code>, <code>type</code>, <code>error</code></li>
    <li><code>disabled</code>, <code>readonly</code>, <code>external-id</code></li>
  </ul>

  <h2><a href="#events" id="events">Events</a></h2>
  <ul>
    <li><code>leChange</code>, <code>leInput</code></li>
    <li><code>leFocus</code>, <code>leBlur</code></li>
  </ul>
</ComponentsPage>
