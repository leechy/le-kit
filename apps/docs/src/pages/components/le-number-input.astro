---
import ComponentsPage from "../../layouts/ComponentsPage.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<ComponentsPage title="le-number-input">
  <h1>&lt;le-number-input&gt;</h1>
  <p>Number input with min/max/step constraints and input/change events.</p>

  <h2><a href="#examples" id="examples">Examples</a></h2>
  <div class="component-example">
    <div style="display: grid; gap: 0.75rem; max-width: 420px;">
      <le-number-input label="Quantity" value="2" min="1" max="10" step="1"></le-number-input>
      <le-number-input label="Price" value="19.99" step="0.01" icon-start="usd"></le-number-input>
    </div>
  </div>

  <CodeBlock language="html" code={`
<le-number-input name="age" label="Age" min="0" max="120"></le-number-input>`}
  />

  <h2><a href="#properties" id="properties">Common Properties / Attributes</a></h2>
  <ul>
    <li><code>value</code>, <code>name</code>, <code>label</code>, <code>placeholder</code></li>
    <li><code>min</code>, <code>max</code>, <code>step</code>, <code>required</code></li>
    <li><code>disabled</code>, <code>readonly</code>, <code>show-spinners</code></li>
  </ul>

  <h2><a href="#events" id="events">Events</a></h2>
  <ul>
    <li><code>leChange</code></li>
    <li><code>leInput</code></li>
  </ul>
</ComponentsPage>
