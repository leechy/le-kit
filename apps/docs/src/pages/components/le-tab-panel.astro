---
import ComponentsPage from "../../layouts/ComponentsPage.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<ComponentsPage title="le-tab-panel">
  <h1>&lt;le-tab-panel&gt;</h1>
  <p>Defines one tab trigger and one panel body when used as a child of <code>&lt;le-tabs&gt;</code>.</p>

  <h2><a href="#examples" id="examples">Examples</a></h2>
  <div class="component-example">
    <le-tabs>
      <le-tab-panel label="First" value="first">
        <p>First panel body.</p>
      </le-tab-panel>
      <le-tab-panel label="Second" value="second" icon-start="star">
        <p>Second panel body.</p>
      </le-tab-panel>
    </le-tabs>
  </div>

  <CodeBlock language="html" code={`
<le-tab-panel label="Overview" value="overview" lazy>
  <p>Lazy-rendered content.</p>
</le-tab-panel>`}
  />

  <h2><a href="#properties" id="properties">Common Properties / Attributes</a></h2>
  <ul>
    <li><code>label</code>, <code>value</code></li>
    <li><code>icon-start</code>, <code>icon-end</code></li>
    <li><code>disabled</code>, <code>lazy</code></li>
  </ul>

  <h2><a href="#events" id="events">Events</a></h2>
  <p>No custom events are listed in the current manifest.</p>
</ComponentsPage>
