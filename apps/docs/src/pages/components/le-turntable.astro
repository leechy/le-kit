<ComponentsPage title="le-turntable">
  <h1>&lt;le-turntable&gt;</h1>
  <p>Legacy rotary selector component useful for wheel-style value picking.</p>

  <h2><a href="#examples" id="examples">Examples</a></h2>
  <div class="component-example">
    <le-turntable value="30" center="Volume" style="display: block; max-width: 280px;"></le-turntable>
  </div>

  <CodeBlock language="html" code={`
<le-turntable center="Tempo" value="120"></le-turntable>`}
  />

  <h2><a href="#properties" id="properties">Common Properties / Attributes</a></h2>
  <ul>
    <li><code>center</code></li>
    <li><code>value</code></li>
  </ul>

  <h2><a href="#events" id="events">Events</a></h2>
  <p>No custom events are listed in the current manifest.</p>
</ComponentsPage>
