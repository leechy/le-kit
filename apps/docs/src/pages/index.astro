---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Le-Kit - The Component Library">
  <main class="bento-page">
    <le-bento-grid
      column-min-width="160"
      column-max-width="200"
      min-columns="2"
      max-columns="6"
      row-height="160"
      gap="16"
      aria-label="Bento Grid Demo"
    >
      <le-bento-tile cols="2" rows="1">
        <a class="tile" href="/components/le-select">
          <div class="tile-type">Featured component</div>
          <div class="tile-content">
            <h3>&lt;le-select&gt;</h3>
            <p>The default dropdown finally gets typeahead capabilities.</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="2">
        <le-card>
          <h1><img slot="header" src="/le-kit.svg" alt="le-kit logo" style="width: 50%;" /></h1>
          <div>
            <h2>The components for your next project</h2>
            <code>Status: NOT_READY_FOR_PRODUCTION</code>
          </div>
        </le-card>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="1">
        <a class="tile" href="/components/le-bento-grid">
          <div class="tile-type">New component</div>
          <div class="tile-content">
            <h3>&lt;le-bento-grid&gt;</h3>
            <p>What you see, right now, is what you get!</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="1" rows="2" class="tone-2">LLMs</le-bento-tile>
      <le-bento-tile cols="2" rows="2" class="tone-6">
        Admin mode? What's that?
      </le-bento-tile>
      <le-bento-tile class="tone-11">Setup Assets</le-bento-tile>
      <le-bento-tile class="tone-12">Get Started</le-bento-tile>
      <le-bento-tile cols="2" rows="1" class="tone-3">
        Styling and Theming
      </le-bento-tile>
    </le-bento-grid>
  </main>

  <style>
    .bento-page {
      padding: var(--le-spacing-4) var(--le-spacing-4) var(--le-spacing-8);
    }

    /*
      Tile background colors are set via --le-bento-tile-bg which is a CSS
      custom property that inherits into the tile's shadow DOM.
      Shadow and border-radius are configured globally below.
    */
    le-bento-grid {
      --le-bento-tile-radius: 0;
      --le-bento-tile-shadow: none;
    }

    le-bento-tile {
      border: 2px solid var(--le-color-border);
      // background-color: var(--le-color-surface);
    }

    .tile {
      display: flex;
      flex-direction: column;
      height: 100%;
      align-items: flex-start;
      justify-content: space-between;
      text-decoration: none;
      color: var(--le-color-text-primary);

      &:hover {
        background-color: color-mix(in srgb, var(--le-color-surface) 42%, transparent);
      }
    }

    .tile-type {
      display: inline-block;
      padding: var(--le-spacing-1) var(--le-spacing-2);
      border-right: 1px solid var(--le-color-border);
      border-bottom: 1px solid var(--le-color-border);

      font-size: var(--le-font-size-sm);
      font-family: var(--le-font-family-mono);
      font-weight: 600;
      color: var(--le-color-border);

      text-transform: uppercase;
      margin-bottom: var(--le-spacing-2);
    }

    .tile-content {
      padding: var(--le-spacing-3);

      h3 {
        margin: 0;
      }
      p {
        margin: var(--le-spacing-2) 0 0;
        font-size: var(--le-font-size-md);
      }
    }

    .tone-1 {
      --le-bento-tile-bg: linear-gradient(145deg, #f59e0b, #f97316);
    }
    .tone-2 {
      --le-bento-tile-bg: linear-gradient(145deg, #22c55e, #16a34a);
    }
    .tone-3 {
      --le-bento-tile-bg: linear-gradient(145deg, #0ea5e9, #0284c7);
    }
    .tone-4 {
      --le-bento-tile-bg: linear-gradient(145deg, #14b8a6, #0f766e);
    }
    .tone-5 {
      --le-bento-tile-bg: linear-gradient(145deg, #ef4444, #dc2626);
    }
    .tone-6 {
      --le-bento-tile-bg: linear-gradient(145deg, #f43f5e, #e11d48);
    }
    .tone-7 {
      --le-bento-tile-bg: linear-gradient(145deg, #84cc16, #65a30d);
    }
    .tone-8 {
      --le-bento-tile-bg: linear-gradient(145deg, #06b6d4, #0891b2);
    }
    .tone-9 {
      --le-bento-tile-bg: linear-gradient(145deg, #f97316, #ea580c);
    }
    .tone-10 {
      --le-bento-tile-bg: linear-gradient(145deg, #10b981, #059669);
    }
    .tone-11 {
      --le-bento-tile-bg: linear-gradient(145deg, #3b82f6, #2563eb);
    }
    .tone-12 {
      --le-bento-tile-bg: linear-gradient(145deg, #eab308, #ca8a04);
    }
  </style>
</Layout>
