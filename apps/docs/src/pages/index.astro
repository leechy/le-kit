---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Le-Kit - The Component Library">
  <main class="bento-page">
    <le-bento-grid
      column-min-width="160"
      column-max-width="200"
      min-columns="2"
      max-columns="6"
      row-height="160"
      gap="16"
      aria-label="Featured components and documentation sections"
    >
      <le-bento-tile cols="2" rows="1">
        <a class="bento-tile" href="/components/le-select">
          <div class="bento-tile-type">Featured component</div>
          <div class="bento-tile-content">
            <h3>&lt;le-select&gt;</h3>
            <p>The default dropdown finally gets typeahead capabilities.</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="2">
        <le-card>
          <h1><img slot="header" src="/le-kit.svg" alt="le-kit logo" style="width: 50%;" /></h1>
          <div>
            <h2>The components for your next project</h2>
            <code>Status: NOT_READY_FOR_PRODUCTION</code>
          </div>
        </le-card>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="1">
        <a class="bento-tile" href="/components/le-bento-grid">
          <div class="bento-tile-type">New component</div>
          <div class="bento-tile-content">
            <h3>&lt;le-bento-grid&gt;</h3>
            <p>What you see, right now, is what you get!</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="1" rows="2">
        <a class="bento-tile" href="/docs/llms">
          <div class="bento-tile-type">Artificial?</div>
          <div class="bento-tile-content">
            <h3>We maybe have a prompt for ya?!?</h3>
            <p>Check out how to tell the LLMs to use Le-Kit components when generating UI code.</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="2" class="tone-6">
        Admin mode? What's that?
      </le-bento-tile>
      <le-bento-tile>
        <a class="bento-tile" href="/docs/assets">
          <div class="bento-tile-content">
            It's can be still tricky with this library!
          </div>
          <div class="bento-tile-content">
            <h3>Setup Assets</h3>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile class="tone-1">
        <a class="bento-tile" href="/docs/start">
          <div class="bento-tile-content">
            <h3>Get Started <le-icon name="arrow-right" /></h3>
          </div>
          <div class="bento-tile-content">
            <p>If you want to experiment with these components, start here.</p>
          </div>
        </a>
      </le-bento-tile>
      <le-bento-tile cols="2" rows="1" class="tone-3">
        Styling and Theming
      </le-bento-tile>
    </le-bento-grid>
  </main>

  <style>
    .tone-1 {
      --le-bento-tile-bg: linear-gradient(145deg, #f59e0b, #f97316);
    }
    .tone-2 {
      --le-bento-tile-bg: linear-gradient(145deg, #22c55e, #16a34a);
    }
    .tone-3 {
      --le-bento-tile-bg: linear-gradient(145deg, #0ea5e9, #0284c7);
    }
    .tone-4 {
      --le-bento-tile-bg: linear-gradient(145deg, #14b8a6, #0f766e);
    }
    .tone-5 {
      --le-bento-tile-bg: linear-gradient(145deg, #ef4444, #dc2626);
    }
    .tone-6 {
      --le-bento-tile-bg: linear-gradient(145deg, #f43f5e, #e11d48);
    }
    .tone-7 {
      --le-bento-tile-bg: linear-gradient(145deg, #84cc16, #65a30d);
    }
    .tone-8 {
      --le-bento-tile-bg: linear-gradient(145deg, #06b6d4, #0891b2);
    }
    .tone-9 {
      --le-bento-tile-bg: linear-gradient(145deg, #f97316, #ea580c);
    }
    .tone-10 {
      --le-bento-tile-bg: linear-gradient(145deg, #10b981, #059669);
    }
    .tone-11 {
      --le-bento-tile-bg: linear-gradient(145deg, #3b82f6, #2563eb);
    }
    .tone-12 {
      --le-bento-tile-bg: linear-gradient(145deg, #eab308, #ca8a04);
    }
  </style>
</Layout>
